generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  services       Service[]
  counters       Counter[]
  tickets        Ticket[]
  advertisements Advertisement[]
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String
  role     String @default("ADMIN")

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  name        String
  prefix      String
  description String?
  icon        String  @default("📋")
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  tickets  Ticket[]
  counters Counter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Counter {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id           String   @id @default(cuid())
  ticketNumber String
  displayNumber Int
  status       String   @default("WAITING")
  
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  counterId String?
  counter   Counter? @relation(fields: [counterId], references: [id], onDelete: SetNull)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  calledAt  DateTime?
  servedAt  DateTime?

  @@index([orgId, status])
  @@index([serviceId, status])
  @@index([createdAt])
}

model Advertisement {
  id        String  @id @default(cuid())
  title     String
  mediaUrl  String
  mediaType String  @default("IMAGE")
  isActive  Boolean @default(true)
  duration  Int     @default(5)
  sortOrder Int     @default(0)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
